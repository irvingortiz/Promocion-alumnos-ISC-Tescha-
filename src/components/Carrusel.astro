---
const fotos = ['/fotos/director/2.jpg', '/fotos/flisol-2026/5.jpg', '/fotos/flisol-2026/4.jpg'];
---
<div x-data="{ actual: 0, fotos: ['/fotos/director/2.jpg', '/fotos/flisol-2026/5.jpg', '/fotos/flisol-2026/4.jpg'] }" 
     x-init="setInterval(() => { actual = (actual + 1) % fotos.length }, 5000)"
     class="relative w-full h-[500px] overflow-hidden rounded-3xl shadow-2xl mt-6">
  <template x-for="(foto, index) in fotos" :key="index">
    <div x-show="actual === index" 
         x-transition:enter="transition ease-out duration-1000"
         x-transition:enter-start="opacity-0 scale-105"
         x-transition:enter-end="opacity-100 scale-100"
         class="absolute inset-0">
      <img :src="foto" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
  </template>
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="text-center p-8 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl shadow-xl">
      <h1 class="text-white text-6xl font-black tracking-widest uppercase">TESCHA</h1>
      <p class="text-white text-xl font-light mt-2">Ingeniería en Sistemas Computacionales</p>
    </div>
  </div>
</div>